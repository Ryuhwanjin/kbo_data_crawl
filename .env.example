# KBO Social Bot API Keys Template

# 1. X (Twitter) API v2 (Developer Portal에서 발급)
X_CONSUMER_KEY="your_consumer_key"
X_CONSUMER_SECRET="your_consumer_secret"
X_ACCESS_TOKEN="your_access_token"
X_ACCESS_TOKEN_SECRET="your_access_token_secret"
X_BEARER_TOKEN="your_bearer_token"

# 2. Meta Threads API (Meta Developer에서 발급)
THREADS_USER_ID="your_threads_account_id"
THREADS_ACCESS_TOKEN="your_threads_long_lived_access_token"

# 3. Imgur API (Imgur API 등록에서 발급 - Threads 이미지 업로드 우회용)
IMGUR_CLIENT_ID="your_imgur_client_id"
